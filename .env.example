# ─── Supabase ─────────────────────────────────────────────────────────────────
# Canonical production project ref (DreamOS86)
# Dashboard: https://supabase.com/dashboard/project/wciioegiczwqlmlroley/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://wciioegiczwqlmlroley.supabase.co
# Anon or publishable key from the SAME project as NEXT_PUBLIC_SUPABASE_URL
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...   # or sb_publishable_... from dashboard

# ─── App ──────────────────────────────────────────────────────────────────────
# Local dev: keep http://localhost:3000 — OAuth/callbacks use this (do not change when switching machines).
# Production Vercel: https://dreamos86.com
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Public marketing/OG links only — can stay https://dreamos86.com in local .env (app still runs on localhost).
NEXT_PUBLIC_SITE_URL=https://dreamos86.com

# ─── AI providers (required for generation to work) ───────────────────────────
ANTHROPIC_API_KEY=sk-ant-api03-...
OPENAI_API_KEY=sk-...
# Gemini (Google) — either name works; GEMINI_API_KEY is enough for local .env
GEMINI_API_KEY=AIza...
# GOOGLE_GENERATIVE_AI_API_KEY=AIza...

# Server-only (never NEXT_PUBLIC)
SUPABASE_SERVICE_ROLE_KEY=eyJ...
# Alternative name: SUPABASE_SECRET_KEY=sb_secret_...

DEEPSEEK_API_KEY=sk-...

# ─── Stripe (optional, for billing) ──────────────────────────────────────────
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...

# ─── Email (Resend — sending only, receiving disabled) ───────────────────────
# RESEND_API_KEY=re_...
# EMAIL_FROM=DreamOS86 <onboarding@resend.dev>
# CONTACT_NOTIFICATIONS_TO=dreamos86app@gmail.com
# SUPPORT_EMAIL=support@dreamos86.com
# PLATFORM_CONTACT_COPY=false
# ADMIN_OTP_SECRET=long-random-secret-for-otp-hashing
#
# DNS (sending only — do NOT change root MX for Gmail receiving):
#   TXT  resend._domainkey
#   MX   send
#   TXT  send
