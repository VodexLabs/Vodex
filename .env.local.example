# ─── Supabase ─────────────────────────────────────────────────────────────────
# From: https://supabase.com/dashboard/project/<project-id>/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
# Dashboard calls this "anon key" or "publishable key" — both are the same JWT/sb_publishable value
NEXT_PUBLIC_SUPABASE_ANON_KEY=<your-anon-or-publishable-key>

# ─── Stripe ────────────────────────────────────────────────────────────────────
# From: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
# From: https://dashboard.stripe.com/apikeys (publishable)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# ─── AI providers ─────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
GOOGLE_GENERATIVE_AI_API_KEY=AIza...

# ─── App ──────────────────────────────────────────────────────────────────────
# Local dev MUST use localhost — do not copy production URL here or navigation/OAuth will leave localhost.
# Production (Vercel): set NEXT_PUBLIC_APP_URL to your deployed origin.
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Optional marketing/canonical URL for production OG + referral links only (not used for in-app navigation in dev).
# NEXT_PUBLIC_SITE_URL=https://dreamos86.com
NEXT_PUBLIC_SUPPORT_EMAIL=support@dreamos86.com

# ─── Resend (transactional email) ─────────────────────────────────────────────
RESEND_API_KEY=re_...
